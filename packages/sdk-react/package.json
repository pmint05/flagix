    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@flagix/sdk-core": "workspace:*",
    "@flagix/shared": "workspace:*",
    "use-sync-external-store": "^1.2.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.10",
    "@types/use-sync-external-store": "^0.0.6",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.7",
    "happy-dom": "^17.1.8",
    "msw": "^2.7.3",
    "typescript": "^6.0.3"
  }
}
